@model IEnumerable<TechMove.Web.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h2>Service Requests</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">New Service Request</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Contract</th>
            <th>Description</th>
            <th>Cost (USD)</th>
            <th>Cost (ZAR)</th>
            <th>Exchange Rate</th>
            <th>Status</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sr in Model)
        {
            <tr>
                <td>@sr.Contract?.ServiceLevel</td>
                <td>@sr.Description</td>
                <td>$@(sr.CostUSD.ToString("F2"))</td>
                <td>R@(sr.CostZAR.ToString("F2"))</td>
                <td>@(sr.ExchangeRateUsed.ToString("F4"))</td>
                <td>
                    <span class="badge
                        @(sr.Status == TechMove.Web.Models.ServiceRequestStatus.Open ? "bg-primary" :
                            sr.Status == TechMove.Web.Models.ServiceRequestStatus.InProgress ? "bg-warning" :
                            sr.Status == TechMove.Web.Models.ServiceRequestStatus.Resolved ? "bg-success" : "bg-secondary")">
                        @sr.Status
                    </span>
                </td>
                <td>@(sr.CreatedAt.ToString("yyyy-MM-dd"))</td>
                <td>
                    <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@sr.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
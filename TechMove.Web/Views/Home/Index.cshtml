@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-5">
    <h1 style="font-size: 3rem; font-weight: 800; color: #1a1a2e;">
        Welcome to <span style="color: #00d4ff;">TechMove</span>
    </h1>
    <p class="lead text-muted">Enterprise Contract & Service Request Management System</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size: 3rem; color: #00d4ff;" class="mb-3">
                <i class="fas fa-users"></i>
            </div>
            <h4 style="font-weight: 700;">Clients</h4>
            <p class="text-muted">Manage your client base, contact details and regions.</p>
            <a asp-controller="Client" asp-action="Index" class="btn btn-primary mt-auto">
                <i class="fas fa-arrow-right me-1"></i>View Clients
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size: 3rem; color: #00d4ff;" class="mb-3">
                <i class="fas fa-file-contract"></i>
            </div>
            <h4 style="font-weight: 700;">Contracts</h4>
            <p class="text-muted">Create and manage contracts with PDF agreement uploads.</p>
            <a asp-controller="Contract" asp-action="Index" class="btn btn-primary mt-auto">
                <i class="fas fa-arrow-right me-1"></i>View Contracts
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <div style="font-size: 3rem; color: #00d4ff;" class="mb-3">
                <i class="fas fa-tools"></i>
            </div>
            <h4 style="font-weight: 700;">Service Requests</h4>
            <p class="text-muted">Log service requests with live USD to ZAR conversion.</p>
            <a asp-controller="ServiceRequest" asp-action="Index" class="btn btn-primary mt-auto">
                <i class="fas fa-arrow-right me-1"></i>View Requests
            </a>
        </div>
    </div>
</div>

<div class="card p-4">
    <h5 style="font-weight: 700; color: #1a1a2e;">
        <i class="fas fa-info-circle me-2" style="color: #00d4ff;"></i>System Features
    </h5>
    <div class="row mt-3">
        <div class="col-md-6">
            <ul class="list-unstyled">
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Client & Contract Management</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>PDF Upload & Download</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Live USD to ZAR Currency Conversion</li>
            </ul>
        </div>
        <div class="col-md-6">
            <ul class="list-unstyled">
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Contract Status Workflow</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Search & Filter by Date and Status</li>
                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Full Audit Trail on Service Requests</li>
            </ul>
        </div>
    </div>
</div>
@model IEnumerable<TechMove.Web.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h2>Contracts</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Contract</a>
</p>

<!-- Search/Filter Form -->
<div class="card mb-4">
    <div class="card-body">
        <h5>Search & Filter</h5>
        <form asp-action="Index" method="get">
            <div class="row">
                <div class="col-md-3">
                    <label>Start Date</label>
                    <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>End Date</label>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>Status</label>
                    <select name="status" class="form-control">
                        <option value="">-- All --</option>
                        @foreach (var s in Enum.GetValues(typeof(TechMove.Web.Models.ContractStatus)))
                        {
                            <option value="@s" selected="@(ViewBag.Status?.ToString() == s.ToString())">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Signed Agreement</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.Client?.Name</td>
                <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <span class="badge
                        @(contract.Status == TechMove.Web.Models.ContractStatus.Active ? "bg-success" :
                            contract.Status == TechMove.Web.Models.ContractStatus.Expired ? "bg-danger" :
                            contract.Status == TechMove.Web.Models.ContractStatus.OnHold ? "bg-warning" : "bg-secondary")">
                        @contract.Status
                    </span>
                </td>
                <td>@contract.ServiceLevel</td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.SignedAgreementFileName))
                    {
                        <a asp-action="Download" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-primary">
                            Download PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No file</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@contract.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
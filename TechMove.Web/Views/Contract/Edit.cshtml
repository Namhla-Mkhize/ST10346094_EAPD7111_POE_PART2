@model TechMove.Web.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<h2>Edit Contract</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SignedAgreementPath" />
            <input type="hidden" asp-for="SignedAgreementFileName" />

            <div class="form-group mb-3">
                <label asp-for="ClientId" class="control-label">Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    @foreach (var s in Enum.GetValues(typeof(TechMove.Web.Models.ContractStatus)))
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <input asp-for="ServiceLevel" class="form-control" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label>Signed Agreement (PDF only)</label>
                @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                {
                    <p class="text-success">Current file: @Model.SignedAgreementFileName</p>
                }
                <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                <small class="text-muted">Leave empty to keep existing file</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
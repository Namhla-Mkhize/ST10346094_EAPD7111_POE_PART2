@model TechMove.Web.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this contract? All associated service requests will also be deleted.
</div>

<div class="card col-md-6">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Client</dt>
            <dd class="col-sm-8">@Model.Client?.Name</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>

            <dt class="col-sm-4">Service Level</dt>
            <dd class="col-sm-8">@Model.ServiceLevel</dd>
        </dl>
    </div>
</div>

<br />
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>